{
    // Project Settings
    "settings.project.name": "fw_al1mb1", // The name of your project (e.g. "fw_al1mb1")
    "settings.project.folder": "${workspaceFolder}/fw_al1mb1", // The path to your project folder (e.g. "/workspace/fw/fw_al1mb1")
    
    // Debugging
    "settings.project.compiledElfFile": "${workspaceFolder}/fw_al1mb1/build/fw_al1mb1.elf", // The path to the compiled .elf file for your project (e.g. "/workspace/project/build/ch.elf")
    "settings.project.svdFile": "${workspaceFolder}/fw_al1mb1/STM32C071.svd", // .svd file (e.g. "/workspace/project/STM32F401.svd")
    "settings.project.device": "STM32C071RB", // Chip name (e.g. "STM32C071RB")

    // Bootloader Settings
    "settings.bootloader.folder": "${workspaceFolder}/bootloader/bootloader", // Path to bootloader project folder

    // OpenOCD Settings
    "settings.openocd.interface": "interface/stlink.cfg", // OpenOCD Debugger interface file (e.g. "interface/stlink.cfg")
    "settings.openocd.board": "board/st_nucleo_c0.cfg", // OpenOCD Board file (e.g. "board/st_nucleo_f4.cfg")

    // Flash Address Settings
    "settings.flash.appAddress": "0x08004000", // Application flash start address
    "settings.flash.bootloaderAddress": "0x08000000", // Bootloader flash start address

    // Serial Monitor Settings
    "settings.serial.baudRate": "115200", // Serial monitor baud rate
    "settings.serial.device0": "/dev/ttyACM0", // First serial device (STM32 USB)
    "settings.serial.device1": "/dev/ttyACM1" // Second serial device (STM32 VCP)
}
