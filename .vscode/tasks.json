{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "options": {
        "presentation": {
            "echo": true,
            "reveal": "always",
            "focus": false,
            "panel": "shared",
            "showReuseMessage": false,
            "clear": true
        }
    },
    "tasks": [

        // Task(s) for the Development Environment
        
        {
            "label": "Clean Application",
            "type": "shell",
            "command": "rm -rf ${config:settings.project.folder}/.dep ${config:settings.project.folder}/build",
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "group": {
                "kind": "build"
            },
            "problemMatcher": [],
            "detail": "Clean application build files"
        },
        {
            "label": "Build Application",
            "type": "shell",
            "command": "make -C ${config:settings.project.folder}",
            "args": [],
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the application"
        },
        {
            "label": "Build Application (DEBUG)",
            "type": "shell",
            "command": "make -C ${config:settings.project.folder} debug",
            "args": [],
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the application with debug enabled"
        },
        {
            "label": "Flash Application (OpenOCD)",
            "type": "shell",
            "command": "pkill -9 openocd || true; openocd -f ${config:settings.openocd.interface} -f ${config:settings.openocd.board} -c \"program build/${config:settings.project.name}_signed.bin ${config:settings.flash.appAddress} verify reset exit\"",
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "Flash signed application via OpenOCD (ST-Link SWD)"
        },
        {
            "label": "Flash Application (st-flash) [BROKEN - DO NOT USE]",
            "type": "shell",
            "command": "echo '=== ST-FLASH IS BROKEN FOR STM32C0 APPLICATION FLASHING ===' && echo 'st-flash erases the bootloader when writing to app region (0x08004000).' && echo 'This is a bug in st-flash with STM32C0 flash handling.' && echo '' && echo 'Use one of these alternatives instead:' && echo '  - Flash Application (OpenOCD)  - recommended' && echo '  - Flash Application (dfu-util) - requires bootloader running' && echo '' && exit 1",
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "BROKEN: st-flash erases bootloader on STM32C0. Use OpenOCD or dfu-util instead."
        },
        {
            "label": "Flash Application (dfu-util)",
            "type": "shell",
            "command": "sudo dfu-util -a 0 --dfuse-address ${config:settings.flash.appAddress}:leave -D build/${config:settings.project.name}_signed.bin",
            "options": {
                "cwd": "${config:settings.project.folder}"
            },
            "dependsOn": "Build Application",
            "group": "build",
            "problemMatcher": [],
            "detail": "Flash signed application via USB DFU (bootloader must be running)"
        },
        {
            "label": "Rebuild Application",
            "dependsOn": [
                "Clean Application",
                "Build Application"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Rebuild (clean and build) the application"
        },
        {
            "label": "Rebuild Application (DEBUG)",
            "dependsOn": [
                "Clean Application",
                "Build Application (DEBUG)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build"
            },
            "detail": "Rebuild (clean and build) the application with debug enabled"
        },


        // Bootloader Tasks
        
        {
            "label": "Build Bootloader",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${config:settings.bootloader.folder}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build the bootloader firmware"
        },
        {
            "label": "Build Bootloader (DEBUG)",
            "type": "shell",
            "command": "make debug",
            "options": {
                "cwd": "${config:settings.bootloader.folder}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build debug bootloader (skips CRC/size validation for debugging)"
        },
        {
            "label": "Clean Bootloader",
            "type": "shell",
            "command": "make clean",
            "options": {
                "cwd": "${config:settings.bootloader.folder}"
            },
            "problemMatcher": [],
            "detail": "Clean bootloader build files"
        },
        {
            "label": "Rebuild Bootloader",
            "dependsOn": [
                "Clean Bootloader",
                "Build Bootloader"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean and rebuild bootloader"
        },
        {
            "label": "Rebuild Bootloader (DEBUG)",
            "dependsOn": [
                "Clean Bootloader",
                "Build Bootloader (DEBUG)"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean and rebuild debug bootloader (skips CRC/size validation for debugging)"
        },
        {
            "label": "Flash Bootloader (OpenOCD)",
            "type": "shell",
            "command": "pkill -9 openocd || true; openocd -f ${config:settings.openocd.interface} -f ${config:settings.openocd.board} -c \"program build/bootloader.bin ${config:settings.flash.bootloaderAddress} verify reset exit\"",
            "options": {
                "cwd": "${config:settings.bootloader.folder}"
            },
            "problemMatcher": [],
            "detail": "Flash bootloader via OpenOCD (ST-Link SWD)"
        },
        {
            "label": "Flash Bootloader (st-flash)",
            "type": "shell",
            "command": "st-flash --reset write build/bootloader.bin ${config:settings.flash.bootloaderAddress}",
            "options": {
                "cwd": "${config:settings.bootloader.folder}"
            },
            "dependsOn": "Build Bootloader",
            "problemMatcher": [],
            "detail": "Flash bootloader via st-flash (ST-Link)"
        },
        {
            "label": "Erase Flash (st-flash)",
            "type": "shell",
            "command": "st-flash erase",
            "problemMatcher": [],
            "detail": "Erase entire flash memory via st-flash (ST-Link)"
        },
        {
            "label": "One-Shot",
            "dependsOn": [
                "Erase Flash (st-flash)",
                "Clean Bootloader",
                "Build Bootloader",
                "Flash Bootloader (OpenOCD)",
                "Clean Application",
                "Build Application",
                "Flash Application (OpenOCD)"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean, build, and flash both bootloader and application (openocd)"
        },
        {
            "label": "One-Shot (DEBUG)",
            "dependsOn": [
                "Erase Flash (st-flash)",
                "Clean Bootloader",
                "Build Bootloader (DEBUG)",
                "Flash Bootloader (OpenOCD)",
                "Clean Application",
                "Build Application (DEBUG)",
                "Flash Application (OpenOCD)"
            ],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean, build (debug), and flash both bootloader and application (openocd)"
        },

        // Serial Monitor Tasks

        {
            "label": "Serial ACM0 (minicom ttyACM0)",
            "type": "shell",
            "command": "sleep 1 ; minicom -D ${config:settings.serial.device0} -b ${config:settings.serial.baudRate}",
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "group": "serial-ports",
                "name": "ttyACM0 @ 115200"
            },
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "reevaluateOnRerun": "onInput"
            }
        },
        {
            "label": "Serial ACM1 (minicom ttyACM1)",
            "type": "shell",
            "command": "sleep 1 ; minicom -D ${config:settings.serial.device1} -b ${config:settings.serial.baudRate}",
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "group": "serial-ports",
                "name": "ttyACM1 @ 115200"
            },
            "isBackground": true,
            "problemMatcher": [],
            "runOptions": {
                "reevaluateOnRerun": "onInput"
            }
        },
        {
            "label": "Monitor All Serial Comm. (STM32 USB, STM32 VCP)",
            "dependsOn": [
                "Serial ACM0 (minicom ttyACM0)",
                "Serial ACM1 (minicom ttyACM1)"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "shell",
                "isDefault": true
            },
            "problemMatcher": []
        }

    ]
}

