{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            // NOTE: STM32C0 (Cortex-M0+) has only (3-4?) hardware breakpoints.
            // Software breakpoints don't work in flash. If breakpoints aren't
            // hitting, check that you haven't exceeded this limit.

            // Bypasses bootloader - flashes signed binary, then sets VTOR, PC, SP directly to application
            "name": "Rebuild and Debug (Direct)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${config:settings.project.folder}",
            "executable": "${config:settings.project.compiledElfFile}",
            "servertype": "openocd",
            "device": "${config:settings.project.device}",
            "configFiles": [
                "${config:settings.openocd.interface}",
                "${config:settings.openocd.board}"
            ],
            "preLaunchTask": "Rebuild Application (DEBUG)",
            "svdFile": "${config:settings.project.svdFile}",
            "runToEntryPoint": "main",
            "loadFiles": [],
            "openOCDLaunchCommands": [
                "program ${config:settings.project.debugSignedBinFile} ${config:settings.flash.appAddress} verify"
            ],
            "postLaunchCommands": [
                "monitor reset halt",
                "set $sp = *(${config:settings.flash.appVectorTable})",
                "set $pc = *(${config:settings.flash.appResetHandler})",
                "monitor mww ${config:settings.flash.vtorRegister} ${config:settings.flash.appVectorTable}"
            ],
            "showDevDebugOutput": "none"
        },
        {
            // Lets bootloader run and validate the signed application
            "name": "Rebuild and Debug (via Bootloader)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${config:settings.project.folder}",
            "executable": "${config:settings.project.compiledElfFile}",
            "servertype": "openocd",
            "device": "${config:settings.project.device}",
            "configFiles": [
                "${config:settings.openocd.interface}",
                "${config:settings.openocd.board}"
            ],
            "preLaunchTask": "Rebuild Application (DEBUG)",
            "svdFile": "${config:settings.project.svdFile}",
            "runToEntryPoint": "main",
            "loadFiles": [],
            "openOCDLaunchCommands": [
                "program ${config:settings.project.debugSignedBinFile} ${config:settings.flash.appAddress} verify"
            ],
            "showDevDebugOutput": "none"
        }
    ]
}
